// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  password      String
  level         Int      @default(1)
  xp            Int      @default(0)
  totalGames    Int      @default(0)
  totalWins     Int      @default(0)
  walletAddress String?  @unique
  walletBalance Decimal  @default(0) @db.Decimal(18, 6)
  avatar        String?
  isAdmin       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  friendsAsUser     Friend[]           @relation("UserFriends")
  friendsAsFriend   Friend[]           @relation("FriendUsers")
  games             GamePlayer[]
  createdGames      Game[]             @relation("GameCreator")
  wonGames          Game[]             @relation("GameWinner")
  gameMoves         GameMove[]
  transactions      Transaction[]
  tournamentEntries TournamentEntry[]
  customizations    UserCustomization?
  sentInvites       GameInvite[]       @relation("InviteSender")
  receivedInvites   GameInvite[]       @relation("InviteReceiver")

  @@index([email])
  @@index([username])
  @@index([walletAddress])
}

model Friend {
  id        String       @id @default(cuid())
  userId    String
  friendId  String
  status    FriendStatus @default(PENDING)
  createdAt DateTime     @default(now())

  user   User @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendUsers", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
  @@index([status])
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model Game {
  id               String     @id @default(cuid())
  roomId           String     @unique
  gameType         GameType
  gameMode         GameMode   @default(CLASSIC)
  maxPlayers       Int
  playersPerTeam   Int? // For team games
  entryFee         Decimal    @db.Decimal(18, 6)
  totalPot         Decimal    @default(0) @db.Decimal(18, 6)
  status           GameStatus @default(WAITING)
  winnerId         String?
  commissionAmount Decimal    @default(0) @db.Decimal(18, 6)
  creatorId        String
  currentTurn      Int? // Current player position
  diceValue        Int?
  gameState        Json? // Store full game state for rejoin
  createdAt        DateTime   @default(now())
  startedAt        DateTime?
  finishedAt       DateTime?

  // Relations
  creator      User          @relation("GameCreator", fields: [creatorId], references: [id])
  winner       User?         @relation("GameWinner", fields: [winnerId], references: [id])
  players      GamePlayer[]
  moves        GameMove[]
  transactions Transaction[]

  @@index([roomId])
  @@index([status])
  @@index([gameType])
  @@index([createdAt])
}

enum GameType {
  SOLO
  TEAM
}

enum GameMode {
  CLASSIC
  RUSH
}

enum GameStatus {
  WAITING
  ACTIVE
  FINISHED
  CANCELLED
}

model GamePlayer {
  id           String       @id @default(cuid())
  gameId       String
  userId       String
  teamId       Int? // For team games
  position     Int // Player position (0-3 for 4 players, etc.)
  color        PlayerColor
  status       PlayerStatus @default(ACTIVE)
  isWinner     Boolean      @default(false)
  payoutAmount Decimal      @default(0) @db.Decimal(18, 6)
  joinedAt     DateTime     @default(now())
  leftAt       DateTime?
  rejoinedAt   DateTime?

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
  @@index([status])
}

enum PlayerColor {
  RED
  BLUE
  GREEN
  YELLOW
}

enum PlayerStatus {
  ACTIVE
  OFFLINE
  FINISHED
  DISCONNECTED
}

model GameMove {
  id           String   @id @default(cuid())
  gameId       String
  playerId     String
  diceRoll     Int
  moveType     MoveType
  fromPosition Int?
  toPosition   Int?
  pieceIndex   Int?
  timestamp    DateTime @default(now())

  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player User @relation(fields: [playerId], references: [id])

  @@index([gameId])
  @@index([playerId])
  @@index([timestamp])
}

enum MoveType {
  DICE_ROLL
  PIECE_MOVE
  PIECE_OUT
  PIECE_HOME
  PIECE_SAFE
}

model GameInvite {
  id         String       @id @default(cuid())
  gameId     String?
  senderId   String
  receiverId String
  status     InviteStatus @default(PENDING)
  entryFee   Decimal?     @db.Decimal(18, 6)
  gameType   GameType?
  maxPlayers Int?
  createdAt  DateTime     @default(now())
  expiresAt  DateTime?

  sender   User @relation("InviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("InviteReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model Tournament {
  id          String           @id @default(cuid())
  name        String
  month       Int
  year        Int
  status      TournamentStatus @default(UPCOMING)
  entryFee    Decimal          @db.Decimal(18, 6)
  prizePool   Decimal          @default(0) @db.Decimal(18, 6)
  startDate   DateTime
  endDate     DateTime
  type        TournamentType   @default(LEADERBOARD)
  bracketData Json? // Store bracket structure for bracket phase
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  entries TournamentEntry[]

  @@unique([month, year])
  @@index([status])
  @@index([startDate])
}

enum TournamentStatus {
  UPCOMING
  LEADERBOARD_PHASE
  BRACKET_PHASE
  FINISHED
  CANCELLED
}

enum TournamentType {
  LEADERBOARD
  BRACKET
  BOTH
}

model TournamentEntry {
  id              String   @id @default(cuid())
  tournamentId    String
  userId          String
  points          Int      @default(0)
  rank            Int?
  bracketPosition Int? // For bracket phase
  wins            Int      @default(0)
  losses          Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
  @@index([points])
  @@index([rank])
}

model UserCustomization {
  id                  String   @id @default(cuid())
  userId              String   @unique
  unlockedBoardColors String[] @default([])
  unlockedPieceStyles String[] @default([])
  selectedBoardColor  String   @default("default")
  selectedPieceStyle  String   @default("default")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  type        TransactionType
  amount      Decimal           @db.Decimal(18, 6)
  status      TransactionStatus @default(PENDING)
  txHash      String?
  gameId      String?
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User  @relation(fields: [userId], references: [id])
  game Game? @relation(fields: [gameId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([txHash])
  @@index([createdAt])
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  ENTRY_FEE
  PAYOUT
  COMMISSION
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model AdminStats {
  id               String   @id @default(cuid())
  date             DateTime @unique @db.Date
  totalGames       Int      @default(0)
  totalDeposits    Decimal  @default(0) @db.Decimal(18, 6)
  totalWithdrawals Decimal  @default(0) @db.Decimal(18, 6)
  totalCommission  Decimal  @default(0) @db.Decimal(18, 6)
  activeUsers      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([date])
}
